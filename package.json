  },
  "homepage": "https://github.com/llrhook/wanna-bet#readme",
  "bugs": {
    "url": "https://github.com/llrhook/wanna-bet/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "discord-js",
    "typescript",
    "bot",
    "gambling",
    "betting",
    "economy",
    "sqlite",
    "better-sqlite3"
  ],
  "scripts": {
