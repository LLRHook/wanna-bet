{
  "name": "wanna-bet",
  "version": "1.0.0",
  "description": "A Discord gambling economy bot — per-guild virtual currency, two-sided bet pools with escrow, an elected admin system, and a full slash command suite.",
  "main": "dist/index.js",
  "author": "Victor Ivanov <victor.n.ivanov@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
